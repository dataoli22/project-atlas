ATLAS_ENV=development
ATLAS_API_URL=http://localhost:8000
ATLAS_APP_URL=http://localhost:3000

ATLAS_DEFAULT_MARKET=IN
ATLAS_DEFAULT_CURRENCY=INR
ATLAS_DEFAULT_LANGUAGE=en

ATLAS_FEATURE_ENDURANCE_ENABLED=true
ATLAS_FEATURE_NUTRITION_ENABLED=true

# ATLAS_OLLAMA_BASE_URL can point at localhost (default, zero-config) or a cloud/hosted Ollama
# endpoint if you set ATLAS_OLLAMA_API_KEY. Either way, calls go directly from this device to
# the provider - never through an Atlas-hosted relay.
ATLAS_OLLAMA_BASE_URL=http://localhost:11434
ATLAS_OLLAMA_MODEL=llama3.1:8b
ATLAS_OLLAMA_EMBED_MODEL=nomic-embed-text
ATLAS_OLLAMA_API_KEY=
# Groq offers a free tier and is a fast cloud option once ATLAS_GROQ_API_KEY is set.
ATLAS_GROQ_MODEL=llama-3.1-8b-instant
ATLAS_GROQ_API_KEY=
# When false (default), Atlas prefers whichever cloud provider is configured (Groq, or Ollama
# pointed at a cloud endpoint) and automatically falls back to on-device Ollama if that call
# fails. Set to true for a hard guarantee that nothing ever leaves this device - it forces
# Ollama and blocks Groq.
ATLAS_LOCAL_ONLY_MODE=false
