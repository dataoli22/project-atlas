{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@atlas/shared": ["packages/shared/src/index.ts"],
      "@atlas/shared/*": ["packages/shared/src/*"],
      "@atlas/config": ["packages/config/src/index.ts"],
      "@atlas/config/*": ["packages/config/src/*"],
      "@atlas/ui": ["packages/ui/src/index.ts"],
      "@atlas/ui/*": ["packages/ui/src/*"]
    }
  }
}
